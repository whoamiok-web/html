/* HEADER */
.header {
  position: sticky; top: 0; z-index: 100;
  background: rgba(13,31,15,0.92); backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.header-inner { max-width: 700px; margin: 0 auto; padding: 14px 20px 0; }
.header-top { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
.header-title { font-family: 'Black Han Sans', sans-serif; font-size: 1.05rem; color: var(--yellow); }
.badge-count { margin-left: auto; background: var(--green-light); color: #fff; font-size: 0.72rem; font-weight: 700; padding: 3px 10px; border-radius: 100px; display: none; }

/* TABS */
.tabs { display: flex; gap: 4px; }
.tab-btn {
  flex: 1; padding: 8px 4px; border: none; cursor: pointer;
  border-radius: 8px 8px 0 0;
  background: transparent; color: rgba(255,255,255,0.4);
  font-size: 0.78rem; font-family: 'Noto Sans KR', sans-serif;
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
}
.tab-btn.active { background: rgba(245,200,0,0.13); color: var(--yellow); font-weight: 700; border-bottom: 2px solid var(--yellow); }
.tab-btn:hover:not(.active) { background: rgba(255,255,255,0.06); }

/* CONTENT */
.content { max-width: 700px; margin: 0 auto; padding: 28px 20px 60px; }
.section { display: none; animation: fadeUp 0.35s ease both; }
.section.active { display: block; }
@keyframes fadeUp { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:translateY(0); } }

/* HERO CARD */
.hero-card {
  background: linear-gradient(135deg, #1a7a2e 0%, #0d3d18 100%);
  border-radius: 20px; padding: 32px 24px; text-align: center;
  border: 1px solid rgba(255,255,255,0.1); position: relative; overflow: hidden; margin-bottom: 16px;
}
.hero-card::before { content:''; position:absolute; top:-30px; right:-30px; width:120px; height:120px; border-radius:50%; background:rgba(255,255,255,0.04); }
.hero-card-emoji { font-size: 2.5rem; margin-bottom: 10px; }
.hero-card-title { font-family: 'Black Han Sans', sans-serif; font-size: 1.8rem; color: var(--yellow); line-height: 1.15; }
.hero-card-sub { margin-top: 10px; font-size: 0.88rem; color: rgba(255,255,255,0.6); }

/* INFO GRID */
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.info-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 18px 16px; }
.info-card-icon { font-size: 1.5rem; margin-bottom: 8px; }
.info-card-label { font-size: 0.7rem; color: rgba(255,255,255,0.4); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.08em; }
.info-card-val { font-weight: 700; font-size: 0.88rem; }

/* NOTICE BOX */
.notice-box { margin-top: 16px; background: rgba(245,200,0,0.07); border-radius: 16px; padding: 18px 20px; }
.notice-box-title { font-weight: 700; color: var(--yellow); margin-bottom: 10px; }
.notice-row { font-size: 0.87rem; color: rgba(255,255,255,0.75); padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
.notice-row:last-child { border-bottom: none; }

/* SECTION TITLE */
.section-title { font-family: 'Black Han Sans', sans-serif; font-size: 1.4rem; color: var(--yellow); margin-bottom: 22px; }

/* TIMELINE */
.timeline-item { display: flex; gap: 16px; padding-bottom: 22px; }
.tl-time { min-width: 58px; font-weight: 700; color: var(--yellow); font-size: 0.88rem; padding-top: 2px; }
.tl-dot-wrap { display: flex; flex-direction: column; align-items: center; }
.tl-dot { width: 12px; height: 12px; border-radius: 50%; background: var(--green-light); border: 2px solid var(--yellow); margin-top: 4px; flex-shrink: 0; }
.tl-line { width: 2px; flex: 1; background: rgba(255,255,255,0.1); margin-top: 4px; min-height: 26px; }
.tl-title { font-weight: 700; font-size: 0.93rem; margin-bottom: 3px; }
.tl-desc { font-size: 0.82rem; color: rgba(255,255,255,0.5); }

/* FORM */
.field { margin-bottom: 16px; }
.field label { display: block; font-size: 0.83rem; color: rgba(255,255,255,0.6); font-weight: 700; margin-bottom: 7px; }
.field input, .field select {
  width: 100%; padding: 13px 15px; border-radius: 12px;
  background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
  color: var(--white); font-size: 1rem; font-family: 'Noto Sans KR', sans-serif;
  transition: border 0.2s;
}
.field input:focus, .field select:focus { border-color: var(--yellow); outline: none; }
.field input.error, .field select.error { border-color: var(--red); }
.field-error { margin-top: 5px; font-size: 0.77rem; color: var(--red); display: none; }
.field-error.show { display: block; }
.field select option { background: #1a2e1c; }

.submit-btn {
  width: 100%; padding: 15px; border-radius: 14px;
  background: var(--yellow); color: var(--dark);
  font-weight: 900; font-size: 1rem; border: none; cursor: pointer;
  font-family: 'Noto Sans KR', sans-serif;
  transition: transform 0.15s, box-shadow 0.15s;
  margin-top: 8px;
}
.submit-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(245,200,0,0.35); }

/* SUCCESS */
.success-msg {
  display: none; background: rgba(45,179,74,0.15);
  border: 1px solid var(--green-light); border-radius: 14px;
  padding: 14px 18px; margin-bottom: 18px;
  color: var(--green-light); font-weight: 700;
  animation: pop 0.4s ease both;
}
.success-msg.show { display: block; }
@keyframes pop { 0%{transform:scale(0.85);opacity:0} 60%{transform:scale(1.04)} 100%{transform:scale(1);opacity:1} }

/* STATS */
.stats-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 20px; }
.stat-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 14px 10px; text-align: center; }
.stat-label { font-size: 0.7rem; color: rgba(255,255,255,0.4); margin-bottom: 5px; }
.stat-val { font-weight: 900; font-size: 1.3rem; color: var(--yellow); }

/* APPLICANT LIST */
.applicant-item {
  background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
  border-radius: 14px; padding: 14px 16px;
  display: flex; align-items: center; gap: 12px; margin-bottom: 10px;
}
.applicant-num { width: 30px; height: 30px; border-radius: 50%; background: var(--green-light); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.83rem; flex-shrink: 0; }
.applicant-name { font-weight: 700; margin-bottom: 3px; }
.applicant-info { font-size: 0.77rem; color: rgba(255,255,255,0.45); }
.cancel-btn {
  margin-left: auto; padding: 6px 12px; border-radius: 8px;
  border: 1px solid rgba(255,77,77,0.3); background: transparent;
  color: rgba(255,77,77,0.7); font-size: 0.77rem; cursor: pointer;
  font-family: 'Noto Sans KR', sans-serif; transition: all 0.2s; flex-shrink: 0;
}
.cancel-btn:hover { background: rgba(255,77,77,0.15); color: var(--red); }

.empty-state { text-align: center; padding: 48px 0; color: rgba(255,255,255,0.3); }
.empty-state-icon { font-size: 2.5rem; margin-bottom: 12px; }

/* GRASS DIVIDER */
.grass { height: 5px; background: repeating-linear-gradient(90deg, var(--green) 0px, var(--green) 40px, var(--green-light) 40px, var(--green-light) 80px); opacity: 0.4; margin: 20px 0; }
