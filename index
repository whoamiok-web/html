<script>
  let applicants = [];
  let currentTab = 0;

  function switchTab(idx) {
    document.querySelectorAll('.section').forEach((s, i) => s.classList.toggle('active', i === idx));
    document.querySelectorAll('.tab-btn').forEach((b, i) => b.classList.toggle('active', i === idx));
    currentTab = idx;
  }

  function handleSubmit() {
    const name = document.getElementById('inputName').value.trim();
    const phone = document.getElementById('inputPhone').value.trim();
    const family = document.getElementById('inputFamily').value;
    const meal = document.getElementById('inputMeal').value;

    let valid = true;

    // reset
    ['inputName','inputPhone'].forEach(id => document.getElementById(id).classList.remove('error'));
    ['errName','errPhone'].forEach(id => { const el = document.getElementById(id); el.textContent=''; el.classList.remove('show'); });

    if (!name) {
      showErr('inputName','errName','이름을 입력해 주세요');
      valid = false;
    } else if (applicants.find(a => a.name === name)) {
      showErr('inputName','errName','이미 신청된 이름입니다');
      valid = false;
    }

    if (!phone) {
      showErr('inputPhone','errPhone','연락처를 입력해 주세요');
      valid = false;
    } else if (!/^[0-9\-]{9,13}$/.test(phone.replace(/ /g,''))) {
      showErr('inputPhone','errPhone','올바른 번호를 입력해 주세요');
      valid = false;
    }

    if (!valid) return;

    applicants.push({ id: Date.now(), name, phone, family, meal });
    document.getElementById('inputName').value = '';
    document.getElementById('inputPhone').value = '';
    document.getElementById('inputFamily').value = '0';
    document.getElementById('inputMeal').value = '있음';

    const msg = document.getElementById('successMsg');
    msg.classList.add('show');
    setTimeout(() => msg.classList.remove('show'), 3000);

    updateStats();
    renderList();
  }

  function showErr(inputId, errId, msg) {
    document.getElementById(inputId).classList.add('error');
    const el = document.getElementById(errId);
    el.textContent = '⚠ ' + msg;
    el.classList.add('show');
  }

  function handleCancel(id) {
    applicants = applicants.filter(a => a.id !== id);
    updateStats();
    renderList();
  }

  function updateStats() {
    const total = applicants.length;
    const fam = applicants.reduce((s,a) => s + Number(a.family), 0);
    document.getElementById('statMembers').textContent = total + '명';
    document.getElementById('statFamily').textContent = fam + '명';
    document.getElementById('statTotal').textContent = (total + fam) + '명';

    const badge = document.getElementById('badgeCount');
    if (total > 0) { badge.style.display = 'inline-block'; badge.textContent = total + '명 신청'; }
    else { badge.style.display = 'none'; }
  }

  function renderList() {
    const el = document.getElementById('applicantList');
    if (applicants.length === 0) {
      el.innerHTML = '<div class="empty-state"><div class="empty-state-icon">⚽</div><div>아직 신청자가 없어요</div></div>';
      return;
    }
    el.innerHTML = applicants.map((a, i) => `
      <div class="applicant-item">
        <div class="applicant-num">${i+1}</div>
        <div style="flex:1">
          <div class="applicant-name">${a.name}</div>
          <div class="applicant-info">${a.phone} · 가족 ${a.family}명 · 식사 ${a.meal}</div>
        </div>
        <button class="cancel-btn" onclick="handleCancel(${a.id})">취소</button>
      </div>
    `).join('');
  }
</script>

</body>
